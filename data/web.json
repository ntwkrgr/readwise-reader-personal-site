      "name": "Revelation",
      "chapters": [
        {
          "number": 1,
          "verses": [
            {"number": 1, "text": "This is the Revelation of Jesus Christ, which God gave him to show to his servants the things which must happen soon, which he sent and made known by his angel to his servant, John,"},
            {"number": 2, "text": "who testified to God's word and of the testimony of Jesus Christ, about everything that he saw."},
            {"number": 3, "text": "Blessed is he who reads and those who hear the words of the prophecy, and keep the things that are written in it, for the time is near."}
